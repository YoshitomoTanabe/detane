// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "detane-devcontainer",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",
	"features": {
		"ghcr.io/devcontainers/features/aws-cli:1": {},
		"ghcr.io/devcontainers-extra/features/aws-cdk:2": {}
	},
	"customizations": {
		"vscode": {
			"settings": {},
			"extensions": [
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"ms-azuretools.vscode-docker",
				"ms-vscode.vscode-typescript-next",
				"amazonwebservices.aws-toolkit-vscode",
				"Orta.vscode-jest",
				"bradlc.vscode-tailwindcss",
				"dsznajder.es7-react-js-snippets",
				"PKief.material-icon-theme",
				"openai.chatgpt"
			]
		}
	},
	"mounts": [
		{
			"source": "${localWorkspaceFolderBasename}-node-modules",
			"target": "/workspaces/${localWorkspaceFolderBasename}/aws-cdk/node_modules",
			"type": "volume"
		},
		{
			"source": "${localWorkspaceFolderBasename}-react-node-modules",
			"target": "/workspaces/${localWorkspaceFolderBasename}/aws-cdk/lib/construct/frontend/react/node_modules",
			"type": "volume"
		}
	],
	"remoteUser": "node",
	"postCreateCommand": "cd aws-cdk/ && sudo chown node:node node_modules && npm install && cd lib/construct/frontend/react && sudo chown node:node node_modules && npm install"
}